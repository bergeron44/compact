# ─── Python Cache Service — Render Production Env Vars ────────────────────
# Copy these into Render Dashboard → Environment Variables
# DO NOT commit real values to git

# Embedding
HUGGINGFACEHUB_API_KEY=hf_your_key_here
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM Chain (add at least one)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# OPENROUTER_API_KEY=your_key_here          # optional
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ChromaDB storage (use /tmp for free plan, /data for paid plan with Disk)
CHROMA_PERSIST_DIR=/tmp/chroma_data

# CORS — set to your Render frontend URL
ALLOWED_ORIGINS=https://compact-frontend.onrender.com
